# Version control ignore files for AI Job Apply Monorepo

# OS files
.DS_Store
Thumbs.db

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Node / Frontend
node_modules/
dist/
build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Python / Backend
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
ENV/
env/

# Database / Local storage
postgres_data/
backend/uploads/resumes/*
!backend/uploads/resumes/mock_john_doe_resume.pdf

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Browser Extension temp profile and simulation captures
browser-extension/temp_chrome_profile/*
browser-extension/connectors/randstad/steps_captured/*
browser-extension/connectors/careerbeacon/steps_captured/*
