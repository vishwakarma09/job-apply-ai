{
  "manifest_version": 3,
  "name": "AI Job Apply Assistant",
  "version": "1.0.0",
  "description": "Scrape LinkedIn job listings, generate cover letters using Cerebras LLM, and track your applications.",
  "permissions": [
    "storage",
    "activeTab",
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.glassdoor.ca/*",
    "https://*.glassdoor.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.randstad.ca/*",
    "https://*.jobbank.gc.ca/*",
    "https://*.careerbeacon.com/*",
    "https://*.vanhack.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.greenhouse.io/*",
        "https://*.glassdoor.ca/*",
        "https://*.glassdoor.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.randstad.ca/*",
        "https://*.jobbank.gc.ca/*",
        "https://*.careerbeacon.com/*",
        "https://*.vanhack.com/*"
      ],
      "js": [
        "common/constants.js",
        "common/helper.js",
        "connectors/linkedin/index.js",
        "connectors/indeed/index.js",
        "connectors/greenhouse/index.js",
        "connectors/glassdoor/index.js",
        "connectors/ziprecruiter/index.js",
        "connectors/randstad/index.js",
        "connectors/jobbank/index.js",
        "connectors/careerbeacon/index.js",
        "connectors/vanhack/index.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.greenhouse.io/*",
        "https://*.glassdoor.ca/*",
        "https://*.glassdoor.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.randstad.ca/*",
        "https://*.jobbank.gc.ca/*",
        "https://*.careerbeacon.com/*",
        "https://*.vanhack.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Job Apply",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
