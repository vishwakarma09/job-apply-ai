{
  "manifest_version": 3,
  "name": "AI Job Apply Assistant",
  "version": "1.0.0",
  "description": "Scrape LinkedIn job listings, generate cover letters using Cerebras LLM, and track your applications.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Job Apply"
  }
}
